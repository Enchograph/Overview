{
  "name": "overview",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.3",
  "scripts": {
    "client:doctor": "flutter doctor",
    "client:analyze": "flutter analyze",
    "client:test": "flutter test",
    "api:dev": "npx pnpm --filter @overview/api dev",
    "api:start": "npx pnpm --filter @overview/api start",
    "api:test": "npx pnpm --filter @overview/api test",
    "api:lint": "npx pnpm --filter @overview/api lint",
    "api:format": "npx pnpm --filter @overview/api format",
    "api:typecheck": "npx pnpm --filter @overview/api typecheck",
    "api:build": "npx pnpm --filter @overview/api build",
    "shared:typecheck": "npx pnpm --filter @overview/shared typecheck",
    "shared:build": "npx pnpm --filter @overview/shared build",
    "shared:check": "npm run shared:build && node --experimental-strip-types scripts/check-shared.ts",
    "test": "npm run api:test",
    "check": "npm run api:lint && npm run api:typecheck && npm run api:test",
    "build": "npm run api:build"
  }
}
