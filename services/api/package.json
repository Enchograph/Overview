{
  "name": "@overview/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "corepack pnpm --filter @overview/shared build",
    "dev": "tsx watch src/index.ts",
    "prestart": "corepack pnpm --filter @overview/shared build",
    "start": "tsx src/index.ts",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "prebuild": "corepack pnpm --filter @overview/shared build",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --check .",
    "pretest": "corepack pnpm --filter @overview/shared build",
    "test": "tsx test/health.test.ts && tsx test/planning.test.ts"
  },
  "dependencies": {
    "@overview/shared": "workspace:*",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "pg": "^8.16.3",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.36.0",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1"
  }
}
